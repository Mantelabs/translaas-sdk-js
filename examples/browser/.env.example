# Translaas API Configuration
# Note: For browser examples, Vite requires environment variables to be prefixed with VITE_
# Copy this file to .env and replace with your actual Translaas API credentials
VITE_TRANSLAAS_API_KEY=your-api-key-here
VITE_TRANSLAAS_BASE_URL=https://api.translaas.com
VITE_TRANSLAAS_PROJECT=translaas-sdk-samples
VITE_TRANSLAAS_DEFAULT_LANGUAGE=en
