# Translaas API Configuration
# Note: For browser examples, you can also configure these directly in app.js
# Copy this file to .env and replace with your actual Translaas API credentials
TRANSLAAS_API_KEY=your-api-key-here
TRANSLAAS_BASE_URL=https://api.translaas.com
TRANSLAAS_PROJECT=translaas-sdk-samples
TRANSLAAS_DEFAULT_LANGUAGE=en
