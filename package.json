{
  "name": "@translaas/sdk",
  "version": "0.5.2-beta",
  "description": "A strongly-typed, performant, and modular JavaScript/TypeScript SDK for consuming the Translaas Translation Delivery API",
  "private": true,
  "workspaces": [
    "packages/@translaas/*"
  ],
  "scripts": {
    "build": "npm run build:models && npm run build:extensions && npm run build:client && npm run build:caching && npm run build:caching-file && npm run build:core",
    "build:models": "npm run build --workspace=@translaas/models",
    "build:client": "npm run build --workspace=@translaas/client",
    "build:caching": "npm run build --workspace=@translaas/caching",
    "build:caching-file": "npm run build --workspace=@translaas/caching-file",
    "build:extensions": "npm run build --workspace=@translaas/extensions",
    "build:core": "npm run build --workspace=@translaas/core",
    "build:watch": "npm run build:watch --workspaces",
    "test": "npm run test --workspaces",
    "test:watch": "npm run test:watch --workspaces",
    "test:coverage": "npm run test:coverage --workspaces",
    "test:integration": "vitest run --config vitest.config.integration.ts",
    "test:integration:watch": "vitest --config vitest.config.integration.ts",
    "test:all": "npm run test && npm run test:integration",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "type-check": "tsc --noEmit",
    "docs": "typedoc",
    "docs:watch": "typedoc --watch",
    "clean": "npm run clean --workspaces && rm -rf node_modules dist coverage .turbo",
    "prepare": "husky install",
    "changeset": "changeset",
    "changeset:version": "changeset version && node scripts/sync-sibling-dependencies.mjs",
    "changeset:publish": "node scripts/sync-sibling-dependencies.mjs validate && changeset publish --no-git-tag",
    "sync:sibling-deps": "node scripts/sync-sibling-dependencies.mjs",
    "validate:sibling-deps": "node scripts/sync-sibling-dependencies.mjs validate",
    "release:git-tag": "node scripts/create-coordinated-release-tag.mjs",
    "version": "npm run changeset:version",
    "release": "npm run build && npm run changeset:publish && npm run release:git-tag"
  },
  "keywords": [
    "translaas",
    "translation",
    "i18n",
    "localization",
    "sdk",
    "typescript",
    "javascript"
  ],
  "author": "Translaas SDK Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/acuencadev/translaas-sdk-js.git"
  },
  "bugs": {
    "url": "https://github.com/acuencadev/translaas-sdk-js/issues"
  },
  "homepage": "https://github.com/acuencadev/translaas-sdk-js#readme",
  "engines": {
    "node": "^20.19.0 || >=22.12.0",
    "npm": ">=9.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.1",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^8.0.3",
    "lint-staged": "^16.4.0",
    "msw": "^2.13.0",
    "prettier": "^3.9.5",
    "typedoc": "^0.28.18",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.2"
  }
}
